rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — vendors, drivers, customers
    match /users/{userId} {
      allow read, write: if true;

      // Vendor menu subcollection permissions
      match /menu/{menuId} {
        allow read, write: if true;
      }
    }

    // Drivers collection
    match /drivers/{driverId} {
      // Anyone can submit a driver application (create)
      allow create: if true;
      // Allow read and update for local operations (Admin Queue and driver updates)
      allow read, update: if true;
      allow delete: if false;
    }

    // Orders collection
    match /orders/{orderId} {
      // Orders are fetched in real-time by drivers and created by webhooks
      allow read, create: if true;
      // Authenticated users (vendors/drivers) can update orders
      allow update: if true;
      allow delete: if false;
    }

    // Finance collection
    match /finance/{financeId} {
      allow read, write: if true;
    }

    // Vendor applications collection
    match /vendor-applications/{appId} {
      allow read, write: if true;
    }

    // Vendors collection
    match /vendors/{vendorId} {
      allow read, write: if true;
    }

    // Payouts — created by vendors, managed by admin
    match /payouts/{payoutId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Vendor requests collection
    match /vendor-requests/{requestId} {
      allow read, write: if true;
    }
  }
}
