{
  "version": 2,
  "cleanUrls": true,
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/shopify-order-created",
      "destination": "/api"
    },
    {
      "source": "/webhooks/shopify-order",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
