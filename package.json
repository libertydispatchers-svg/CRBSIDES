{
  "name": "curbside-ops-engine",
  "version": "1.0.0",
  "description": "Curbside Operations Engine - Root Workspace",
  "scripts": {
    "frontend:install": "cd frontend && npm install",
    "frontend:build": "cd frontend && npm run build",
    "frontend:dev": "cd frontend && npm run dev",
    "functions:install": "cd functions && npm install",
    "build": "cd frontend && npm install && npm run build",
    "emulators": "export PATH=\"/Users/STUDIO/node-v22/bin:$PATH\" && npx -y firebase-tools@latest emulators:start",
    "dev": "export PATH=\"/Users/STUDIO/node-v22/bin:$PATH\" && npm run frontend:build && npm run emulators"
  },
  "private": true,
  "dependencies": {
    "axios": "^1.18.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase-admin": "^12.0.0"
  }
}
